# Infrastructure
DATABASE_URL=postgres://curator:curator@localhost:5432/review_curator?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# Browser
BROWSER_POOL_SIZE=3

# Queue concurrency
CRAWL_QUEUE_CONC=5
NORM_QUEUE_CONC=10

# Proxy providers (comma-separated)
PROXY_URLS=http://user:pass@proxy1.brightdata.com:22225,http://user:pass@proxy2.oxylabs.io:60000

# Captcha solving
TWO_CAPTCHA_KEY=your_2captcha_key_here
ANTI_CAPTCHA_KEY=your_anticaptcha_key_here

# Observability
OTEL_ENDPOINT=localhost:4317

# Rate limiting (requests per second per domain; 0.033 = 1 req per 30s)
RATE_LIMIT_PER_SEC=0.033
